# =============================================================================
# config/build.env — Build configuration
# These values are loaded by the Makefile and passed as Docker env vars.
# Edit this file to customize your build.
# =============================================================================

# ── Image sizing ──────────────────────────────────────────────────────────────
# Total image size in MB — should match or be smaller than your smallest USB
# Common values: 8192 (8GB), 16384 (16GB), 32768 (32GB)
IMAGE_SIZE_MB=8192

# EFI/boot partition size in MB (256 is plenty)
BOOT_SIZE_MB=256

# OS/root partition size in MB — rest becomes the data partition
# 4096 (4GB) is comfortable for xemu + drivers
SYSTEM_SIZE_MB=4096

# ── Alpine ────────────────────────────────────────────────────────────────────
ALPINE_BRANCH=edge
ALPINE_MIRROR=https://dl-cdn.alpinelinux.org/alpine
ARCH=x86_64

# ── xemu install method ───────────────────────────────────────────────────────
# auto      = try apk package first, fall back to AppImage
# package   = apk only (fails if not in repos)
# appimage  = always use GitHub AppImage release
XEMU_USE_APPIMAGE=auto

# ── Driver options ────────────────────────────────────────────────────────────
# Include Nvidia open kernel modules (requires Turing+ GPU, GTX 1600 / RTX)
ENABLE_NVIDIA_OPEN=true

# ── Audio ─────────────────────────────────────────────────────────────────────
# true = PipeWire (recommended, better latency)
# false = ALSA only (simpler, more compatible)
ENABLE_PIPEWIRE=true

# ── Misc ──────────────────────────────────────────────────────────────────────
# Pre-create a blank 8GB qcow2 Xbox HDD image in the data partition
CREATE_XBOX_HDD=true

# Output image filename (without .img extension)
IMAGE_NAME=xemu-kiosk

#

kioskappname=XemuBOX
kioskshortenedname=xemu
kioskusername=xemu
kioskuserhome=xemu

firstbootname=XemuBOX FirstBoot Service
firstbootdesc=Expands XemuBOX's Data partition to fill the drive upon first boot.
firstbootflag=/var/.XemuBOX-firstboot

kioskrootpartlabel=XemuBOXRoot
kioskbootpartlabel=XemuBOXBoot
kioskdatapartlabel=XemuBOXData

hostname=xemubox

#

XEMUHDD_IMGDIR=/media/data/xbox/xbox_hdd.qcow2
XEMUMCPX_IMGDIR=/media/data/xbox/mcpx_1.0.bin
XEMUBIOS_IMGDIR=/media/data/xbox/bios.bin

XEMU_ARGS=--full-screen